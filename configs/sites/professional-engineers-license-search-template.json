{
  "schema": "web-seek.site-config.v1",
  "id": "professional-engineers-license-search-template",
  "name": "Professional Engineers License Search Template",
  "jurisdiction": "Replace with state name",
  "startUrl": "https://example.gov/license-search",
  "description": "Template for state board license search pages. Replace selectors and URL with the state's public lookup site.",
  "tags": ["template", "professional-engineers", "government-data"],
  "createdAt": "2026-04-23T00:00:00.000Z",
  "updatedAt": "2026-04-23T00:00:00.000Z",
  "browser": {
    "headless": false,
    "viewport": {
      "width": 1440,
      "height": 1000
    },
    "slowMoMs": 50
  },
  "humanInLoop": {
    "enabled": true,
    "pauseBeforeRun": false,
    "challengeDetection": true,
    "instructions": "If a CAPTCHA, terms screen, or session timeout appears, solve it in the browser and return to the CLI."
  },
  "steps": [
    {
      "id": "open-license-search",
      "type": "navigate",
      "label": "Open state license search",
      "optional": false,
      "url": "https://example.gov/license-search",
      "waitUntil": "domcontentloaded"
    },
    {
      "id": "human-review-search-form",
      "type": "human-checkpoint",
      "label": "Review search form",
      "optional": false,
      "reason": "Confirm the public search form is loaded and solve any human challenge."
    },
    {
      "id": "fill-last-name",
      "type": "fill",
      "label": "Last name search input",
      "optional": true,
      "selector": "input[name='lastName']",
      "value": "{{input:lastName|Last name, or blank for all}}",
      "timeoutMs": 15000
    },
    {
      "id": "select-profession",
      "type": "select",
      "label": "Profession filter",
      "optional": true,
      "selector": "select[name='profession']",
      "value": "Professional Engineer",
      "timeoutMs": 15000
    },
    {
      "id": "submit-search",
      "type": "click",
      "label": "Submit search",
      "optional": false,
      "selector": "button[type='submit']",
      "timeoutMs": 15000
    },
    {
      "id": "wait-results",
      "type": "wait-for-selector",
      "label": "Wait for result table",
      "optional": false,
      "selector": "table.results",
      "timeoutMs": 30000
    },
    {
      "id": "extract-engineers",
      "type": "extract-table",
      "label": "Extract professional engineer rows",
      "optional": false,
      "selector": "table.results",
      "rowSelector": "tbody tr",
      "fields": [
        {
          "name": "license_number",
          "selector": "td:nth-of-type(1)",
          "attribute": "text",
          "required": true,
          "transform": "trim"
        },
        {
          "name": "name",
          "selector": "td:nth-of-type(2)",
          "attribute": "text",
          "required": true,
          "transform": "trim"
        },
        {
          "name": "status",
          "selector": "td:nth-of-type(3)",
          "attribute": "text",
          "required": false,
          "transform": "license-status"
        },
        {
          "name": "city",
          "selector": "td:nth-of-type(4)",
          "attribute": "text",
          "required": false,
          "transform": "trim"
        },
        {
          "name": "profile_url",
          "selector": "td:nth-of-type(2) a",
          "attribute": "href",
          "required": false,
          "transform": "trim"
        }
      ],
      "pagination": {
        "nextSelector": "a[rel='next'], button.next",
        "maxPages": 50,
        "waitAfterMs": 1000,
        "stopWhenSelectorDisabled": true
      },
      "outputKey": "engineers"
    }
  ],
  "output": {
    "format": "both",
    "directory": "exports"
  }
}
